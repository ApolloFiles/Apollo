{
  "name": "apollo-backend",
  "version": "0.0.1-SNAPSHOT",
  "private": true,
  "description": "",
  "homepage": "https://github.com/ApolloFiles/Apollo#readme",
  "license": "GPL-3.0-or-later",
  "keywords": [],
  "author": {
    "name": "Christian Koop",
    "url": "https://github.com/SpraxDev"
  },
  "contributors": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ApolloFiles/Apollo.git"
  },
  "bugs": {
    "url": "https://github.com/ApolloFiles/Apollo/issues"
  },
  "main": "src/main.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",

    "test": "npm run type-check && vitest --run",
    "test:watch": "vitest",
    "test:coverage": "npm run test -- --coverage",
    "test:ci": "npm run test:coverage -- --reporter github-actions",
    "type-check": "tsc --noEmit",

    "dev": "node --watch --env-file .env --loader ts-node/esm --enable-source-maps src/main.ts",

    "prisma:generate": "prisma generate --no-engine --schema ./prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema ./prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema ./prisma",
    "prisma:dump-better-auth-schema": "npx @better-auth/cli generate --output prisma/models/better-auth.prisma"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "dependencies": {
    "@orpc/server": "^1.10.2",
    "@prisma/client": "^6.18.0",
    "@sentry/node": "^10.22.0",
    "@spraxdev/node-commons": "github:SpraxDev/Node-Commons#9e15d1631d46e845ec9839b38b09201b659d1475",
    "@types/mime-types": "^3.0.1",
    "better-auth": "^1.3.34",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.1.0",
    "mime-types": "^3.0.1",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5",
    "tsyringe": "^4.10.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.1",
    "@types/node": "^24.9.2",
    "@vitest/coverage-v8": "^4.0.6",
    "prisma": "^6.18.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.6",
    "vitest-mock-extended": "^3.1.0"
  }
}
