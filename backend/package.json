{
  "name": "apollo-backend",
  "version": "0.0.1-SNAPSHOT",
  "private": true,
  "description": "",
  "homepage": "https://github.com/ApolloFiles/Apollo#readme",
  "license": "GPL-3.0-or-later",
  "keywords": [],
  "author": {
    "name": "Christian Koop",
    "url": "https://github.com/SpraxDev"
  },
  "contributors": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ApolloFiles/Apollo.git"
  },
  "bugs": {
    "url": "https://github.com/ApolloFiles/Apollo/issues"
  },
  "main": "src/main.ts",
  "type": "module",
  "scripts": {
    "postinstall": "npm run prisma:generate",

    "build": "tsc",
    "build:podman": "cd .. && podman build --file Containerfile --pull=newer --rm --target ffmpeg-cuda --tag localhost/spraxdev/apollo:latest .",

    "test": "npm run type-check && vitest --run",
    "test:watch": "vitest",
    "test:coverage": "npm run test -- --coverage",
    "test:ci": "npm run test:coverage -- --reporter github-actions",
    "type-check": "tsc --noEmit",

    "dev": "node --watch --env-file .env --loader ts-node/esm --enable-source-maps src/main.ts",

    "prisma:generate": "prisma generate --require-models",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:production": "prisma migrate deploy",
    "prisma:dump-better-auth-schema": "npx @better-auth/cli generate --output prisma/models/better-auth.prisma",

    "contributors:add": "npx all-contributors add --config ../.all-contributorsrc",
    "contributors:generate": "npx all-contributors generate --config ../.all-contributorsrc"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "@orpc/server": "^1.12.2",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "@sentry/node": "^10.29.0",
    "@spraxdev/node-commons": "github:SpraxDev/Node-Commons#9e15d1631d46e845ec9839b38b09201b659d1475",
    "@types/mime-types": "^3.0.1",
    "better-auth": "^1.4.5",
    "fastify": "^5.6.2",
    "fastify-plugin": "^5.1.0",
    "mime-types": "^3.0.2",
    "range-parser": "^1.2.1",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5",
    "tsyringe": "^4.10.0",
    "ws": "^8.18.3",
    "zod": "^4.1.13"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.9"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.3",
    "@types/node": "^24.10.1",
    "@types/range-parser": "^1.2.7",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.15",
    "prisma": "^7.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15",
    "vitest-mock-extended": "^3.1.0"
  }
}
