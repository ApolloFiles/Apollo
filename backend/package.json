{
  "name": "apollo-backend",
  "version": "0.0.1-SNAPSHOT",
  "private": true,
  "description": "",
  "homepage": "https://github.com/ApolloFiles/Apollo#readme",
  "license": "GPL-3.0-or-later",
  "keywords": [],
  "author": {
    "name": "Christian Koop",
    "url": "https://github.com/SpraxDev"
  },
  "contributors": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ApolloFiles/Apollo.git"
  },
  "bugs": {
    "url": "https://github.com/ApolloFiles/Apollo/issues"
  },
  "main": "src/main.ts",
  "type": "module",
  "scripts": {
    "postinstall": "npm run prisma:generate",

    "build": "tsc",
    "build:podman": "cd .. && podman build --file Containerfile --pull=newer --rm --target ffmpeg-cuda --tag localhost/spraxdev/apollo:latest .",

    "test": "npm run type-check && vitest --run",
    "test:watch": "vitest",
    "test:coverage": "npm run test -- --coverage",
    "test:ci": "npm run test:coverage -- --reporter github-actions",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",

    "dev": "node --watch --env-file .env --import @swc-node/register/esm-register --enable-source-maps src/main.ts",

    "prisma:generate": "prisma generate --require-models",
    "prisma:migrate:dev": "prisma migrate dev && npm run prisma:generate",
    "prisma:migrate:production": "prisma migrate deploy",

    "contributors:add": "npx all-contributors add --config ../.all-contributorsrc",
    "contributors:generate": "npx all-contributors generate --config ../.all-contributorsrc"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/websocket": "^11.2.0",
    "@orpc/contract": "^1.13.14",
    "@orpc/server": "^1.13.14",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@sentry/node": "^10.48.0",
    "@spraxdev/node-commons": "github:SpraxDev/Node-Commons#4a609c65c4a07aaae47cbeb0eb713b21e6621ceb",
    "@types/mime-types": "^3.0.1",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "mime-types": "^3.0.2",
    "openid-client": "^6.8.2",
    "range-parser": "^1.2.1",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5",
    "tsyringe": "^4.10.0",
    "ws": "^8.20.0",
    "xxhash-addon": "^2.1.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@types/range-parser": "^1.2.7",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.4",
    "prisma": "^7.6.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "vitest-mock-extended": "^4.0.0"
  }
}
