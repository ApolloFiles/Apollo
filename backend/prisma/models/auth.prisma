model AuthUser {
  id               String    @id @default(dbgenerated("apollo_nanoid(19)"))
  displayName      String    @map("display_name")
  blocked          Boolean   @default(false) @map("is_blocked")
  isSuperUser      Boolean   @default(false) @map("is_super_user")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  lastLoginDate    DateTime? @map("last_login_date") @db.Timestamptz()
  lastActivityDate DateTime? @map("last_activity_date") @db.Timestamptz()
  profilePicture   Bytes?    @map("profile_picture")

  linkedAuthProviders             AuthUserLinkedProvider[]
  sessions                        AuthSession[]
  mediaLibraries                  MediaLibrary[]
  mediaLibrarySharedWiths         MediaLibrarySharedWith[]
  mediaLibraryUserWatchProgresses MediaLibraryUserWatchProgress[]

  @@index([createdAt])
  @@map("auth_users")
}

model AuthUserLinkedProvider {
  userId                     String   @map("user_id")
  providerId                 String   @map("provider_id")
  providerUserId             String   @map("provider_user_id")
  providerUserDisplayName    String?  @map("provider_user_display_name")
  providerUserProfilePicture Bytes?   @map("provider_user_profile_picture")
  linkedAt                   DateTime @default(now()) @map("linked_at") @db.Timestamptz()

  providerUser AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, providerId])
  @@unique([providerId, providerUserId])
  @@index([userId])
  @@map("auth_users_linked_providers")
}

model AuthSession {
  id                BigInt   @id @default(dbgenerated("generate_snowflake('auth_sessions_id_seq'::text)"))
  hashedToken       Bytes    @unique @map("hashed_token")
  userId            String   @map("user_id")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  expiresAt         DateTime @map("expires_at") @db.Timestamptz()
  userAgent         String   @map("user_agent")
  roughLastActivity DateTime @map("rough_last_activity") @db.Timestamptz()

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model AuthAnonymousSession {
  hashedToken Bytes    @id @map("hashed_token")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  expiresAt   DateTime @default(dbgenerated("(now() + '00:10:00'::interval)")) @map("expires_at") @db.Timestamptz()
  data        Json     @db.JsonB

  @@index([expiresAt])
  @@map("auth_anonymous_sessions")
}

model AuthAccountCreationInviteToken {
  hashedToken            Bytes    @id @map("hashed_token")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz()
  expiresAt              DateTime @map("expires_at") @db.Timestamptz
  createSuperUserAccount Boolean  @default(false)

  @@index([expiresAt])
  @@map("auth_account_creation_invite_tokens")
}
