model MediaLibrary {
  id            BigInt   @id @default(dbgenerated("generate_snowflake('media_libraries_id_seq'::text)"))
  ownerId       String   @map("owner_id")
  name          String   @db.VarChar(256)
  directoryUris String[] @map("directory_uris")

  media                  MediaLibraryMedia[]
  MediaLibrarySharedWith MediaLibrarySharedWith[]

  @@map("media_libraries")
  @@schema("public")
}

model MediaLibrarySharedWith {
  libraryId BigInt @map("library_id")
  userId    String @map("user_id")

  library MediaLibrary @relation(fields: [libraryId], references: [id], onDelete: Cascade)

  @@id([libraryId, userId])
  @@map("media_libraries_shared_with")
  @@schema("public")
}

model MediaLibraryMedia {
  id                   BigInt    @id @default(dbgenerated("generate_snowflake('media_libraries_media_id_seq'::text)"))
  libraryId            BigInt    @map("library_id")
  title                String
  synopsis             String?
  directoryUri         String    @map("directory_uri")
  addedAt              DateTime  @default(now()) @map("added_at") @db.Timestamptz()
  externalApiFetchedAt DateTime? @map("external_api_fetched_at") @db.Timestamptz()

  library                         MediaLibrary                      @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  items                           MediaLibraryMediaItem[]
  mediaLibraryMediaExternalIds    MediaLibraryMediaExternalIds[]
  mediaLibraryMediaFallbackImages MediaLibraryMediaFallbackImages[]

  @@unique([libraryId, directoryUri])
  @@map("media_libraries_media")
  @@schema("public")
}

model MediaLibraryMediaItem {
  id                   BigInt    @id @default(dbgenerated("generate_snowflake('media_libraries_media_items_id_seq'::text)"))
  mediaId              BigInt    @map("media_id")
  relativeFilePath     String    @map("relative_file_path")
  durationInSec        Int       @map("duration_in_sec")
  title                String
  synopsis             String?
  seasonNumber         Int?      @map("season_number")
  episodeNumber        Int?      @map("episode_number")
  lastScannedAt        DateTime  @default(now()) @map("last_scanned_at") @db.Timestamptz()
  addedAt              DateTime  @default(now()) @map("added_at") @db.Timestamptz()
  externalApiFetchedAt DateTime? @map("external_api_fetched_at") @db.Timestamptz()

  media             MediaLibraryMedia               @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  userWatchProgress MediaLibraryUserWatchProgress[]

  @@unique([mediaId, relativeFilePath])
  @@map("media_libraries_media_items")
  @@schema("public")
}

model MediaLibraryUserWatchProgress {
  userId        String   @map("user_id")
  mediaItemId   BigInt   @map("media_item_id")
  durationInSec Int      @map("duration_in_sec")
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  mediaItem MediaLibraryMediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  @@id([userId, mediaItemId])
  @@map("media_libraries_user_watch_progress")
  @@schema("public")
}

model MediaLibraryMediaExternalIds {
  mediaId    BigInt                            @map("media_id")
  source     MediaLibraryMediaExternalIdSource
  externalId String                            @map("external_id")

  media MediaLibraryMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([mediaId, source])
  @@map("media_libraries_media_external_ids")
  @@schema("public")
}

model MediaLibraryMediaFallbackImages {
  mediaId BigInt                             @map("media_id")
  type    MediaLibraryMediaFallbackImageType
  image   Bytes

  media MediaLibraryMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([mediaId, type])
  @@map("media_libraries_media_fallback_images")
  @@schema("public")
}

enum MediaLibraryMediaExternalIdSource {
  THE_MOVIE_DB
  IMDB
  THE_TV_DB

  @@map("media_library_media_external_id_source")
  @@schema("public")
}

enum MediaLibraryMediaFallbackImageType {
  POSTER
  BACKDROP
  LOGO

  @@map("media_library_media_fallback_image_type")
  @@schema("public")
}
